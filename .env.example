# ─────────────────────────────────────────────────────────────
# SnapBack — environment template
# Copy to .env.local and fill in the blanks. .env* is gitignored.
# ─────────────────────────────────────────────────────────────

# ── Circle (server-only; never expose to the browser) ──────────
# console.circle.com → API Keys. Use a TESTNET key.
CIRCLE_API_KEY=
# 32-byte hex entity secret, registered via the Circle entity-secret flow.
CIRCLE_ENTITY_SECRET=

# Separate PRODUCTION Circle entity credentials (lib/circle.ts's
# getLiveDeveloperControlledWalletsClient) — Circle segregates sandbox and
# production wallets entirely. This is the only client that can see or sign
# for the `parallel_payer` wallet (real Base mainnet, real USDC). Do not
# reuse the sandbox CIRCLE_API_KEY/CIRCLE_ENTITY_SECRET above here.
CIRCLE_LIVE_API_KEY=
CIRCLE_LIVE_ENTITY_SECRET=

# ── Circle User-Controlled Wallets (web SDK) ───────────────────
# App ID from console.circle.com (public; used by the browser web SDK for email OTP).
NEXT_PUBLIC_CIRCLE_APP_ID=
# Server-side secret for signing session cookies (generate: openssl rand -hex 32).
SESSION_SECRET=

# ── Supabase ───────────────────────────────────────────────────
# Project Settings → API. URL + anon/publishable key are public (NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service role key is SECRET — server-side only, bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Arc Testnet (public network config) ────────────────────────
# NOTE: Arc docs list the RPC as *.arc.network; the build brief said *.arc.io.
# Defaulting to the docs value. Override here if your environment differs.
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_ARC_FAUCET_URL=https://faucet.circle.com

# Native gas token = USDC with 18 decimals (do NOT mix with the 6-dec ERC-20).
# ERC-20 USDC interface over the native balance — 6 decimals.
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Circle Gateway on Arc Testnet (domain 26).
NEXT_PUBLIC_ARC_GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
NEXT_PUBLIC_ARC_GATEWAY_MINTER=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B
NEXT_PUBLIC_ARC_GATEWAY_DOMAIN=26

# ── Estimator Agent (Claude spec parser, server-only) ──────────
# platform.claude.com → API keys. Used to parse quote requests into a structured spec.
ANTHROPIC_API_KEY=
# Nanopayment charged into quote-phase escrow from the 3rd attempt onward.
ESTIMATOR_QUOTE_FEE_USDC=0.05

# Fee-inclusive quote: happy-path platform skim, buyer-side, added on top of
# the seller cost estimate (not deducted from the seller's payout).
ESTIMATOR_HAPPY_PATH_FEE_PCT=0.00075
# Fixed fee recovering the buyer-agent validator's real LLM-call cost
# (lib/validator.ts, measured ~$0.016-0.02/call) — always charged (validation
# always runs, approve or reject), folded into guaranteed_total_usdc like the
# happy-path fee above, shown as its own disclosed line item. Not a % of
# price: the validator's cost is roughly fixed per call regardless of task
# size, so a % fee alone badly undershoots it on small tasks.
ESTIMATOR_VALIDATION_FEE_USDC=0.03
# Dispute-insurance premium: unconditional, non-refundable % of the seller
# cost estimate, folded into guaranteed_total_usdc like the two fees above.
# Funds the full-refund guarantee on a buyer-won standard dispute (real
# Claude+Parallel execution cost is spent before any dispute exists, and
# refunds in full on a win — see lib/estimator/fees.ts's
# disputeInsurancePremiumPct docblock for the break-even math). PROVISIONAL —
# sized from a thin sample (8 real disputes), meant to be revised as real
# dispute volume grows, not a permanent number.
ESTIMATOR_DISPUTE_INSURANCE_PREMIUM_PCT=0.0417
# Micro-vs-large transaction fee tier for the disclosed contingent arbitration
# fee (only charged if a dispute occurs — never folded into guaranteed_total).
ESTIMATOR_MICRO_TX_THRESHOLD_USDC=50
ESTIMATOR_ARBITRATION_FEE_PCT_MICRO=0.02
ESTIMATOR_ARBITRATION_FEE_PCT_LARGE=0.01

# ── Buyer dispute-abuse tracking ────────────────────────────────
# Window of resolved disputes a buyer's loss rate is computed over (used only
# for the tighter-scrutiny flag below).
DISPUTE_ABUSE_LOOKBACK_N=5
# Harder threshold — crossing this flags the buyer for tighter validator
# scrutiny on future tasks (see lib/disputes/service.ts).
DISPUTE_HARD_ABUSE_LOSS_RATE=0.8

# ── Post-approval contest ───────────────────────────────────────
# Window after auto-approve a buyer can still contest — matches the accept window.
# Contest filing fee itself is a flat 50% of the task's initial quote
# (lib/disputes/service.ts's CONTEST_FEE_PCT — not env-configurable, no
# per-buyer escalation) and only ever applies here: a standard dispute is
# always system auto-filed on a validator rejection and never charges
# anything (see lib/validator-service.ts).
POST_APPROVAL_CONTEST_WINDOW_HOURS=24

# Shared secret for the keeper/cron sweep endpoint (openssl rand -hex 24).
KEEPER_SECRET=

# Only read by `npm run webhooks:setup` (scripts/circle-webhooks-setup.ts),
# never by the running app — the public HTTPS URL Circle should deliver
# contract-event/wallet-tx webhooks to. An ngrok forwarding URL in local dev,
# the real deployment URL once one exists. See README "Event-driven state".
WEBHOOK_PUBLIC_URL=

# Foundry deployer keystore password (Arc testnet only).
DEPLOYER_KEYSTORE_PASSWORD=

# ── SnapBack contracts (Arc Testnet) ──────────────────────────
# SnapBackEscrow is a standalone escrow (holds USDC directly) as of the
# contracts/script/DeployStandaloneEscrow.s.sol deployment — no longer an
# ERC-8183 hook on AgenticCommerce. That integration reverted
# HookNotWhitelisted() on every real call: AgenticCommerce's ADMIN_ROLE is
# held by a third-party address (verified on-chain), and no self-service
# whitelisting path exists in the Arc docs. See SnapBackEscrow.sol's
# docblock for the full story. NEXT_PUBLIC_ARC_AGENTIC_COMMERCE below is
# unused by app code now — kept only for reference.
NEXT_PUBLIC_SNAPBACK_ESCROW=
NEXT_PUBLIC_QUOTE_ESCROW=
NEXT_PUBLIC_JUDGE_REGISTRY=
NEXT_PUBLIC_ARC_AGENTIC_COMMERCE=0x0747EEf0706327138c69792bF28Cd525089e4583
NEXT_PUBLIC_ERC8004_IDENTITY=0x8004A818BFB912233c491871b3d84c89A494BD9e
NEXT_PUBLIC_ERC8004_REPUTATION=0x8004B663056A597Dffe9eCcC1965A193B7388713

# ── Admin access ────────────────────────────────────────────────
# Comma-separated wallet addresses allowlisted for /admin.
ADMIN_WALLET_ADDRESSES=

# ── Demo mode (judge/demo access only — leave off in production) ─
# Shows two one-click login buttons on /login: testAccount@snapback.com
# (persistent seeded activity) and newAccount@snapback.com (resets to a
# clean first-time state on every select). Bypasses real email-OTP for
# those two accounts only; the real login path is unaffected either way.
NEXT_PUBLIC_DEMO_MODE=false
